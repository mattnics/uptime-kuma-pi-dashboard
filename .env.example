# Uptime Kuma instance URL (no trailing slash)
UPTIME_KUMA_URL=http://100.82.211.69:3010

# Public status page slug from Uptime Kuma → Status Pages
# Example: if your page is at http://100.82.211.69:3010/status/my-services, use "my-services"
STATUS_PAGE_SLUG=your-status-page-slug

# Local port for the Pi dashboard
PORT=3080

# How often to refresh data from Uptime Kuma (milliseconds)
POLL_INTERVAL_MS=20000
